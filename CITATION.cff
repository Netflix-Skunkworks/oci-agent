        given-names: Marc
      - family-names: Cervone
        given-names: Dan
    journal: "Statistical Science"
    volume: 34
    issue: 1
    year: 2019
    pages: "43-68"
    doi: "10.1214/18-STS667"
    notes: "ACIC 2016 competition reference. The 77-DGP benchmark used here is the data release from this challenge."

  - type: software
    title: "EconML: A Python Package for ML-Based Heterogeneous Treatment Effects Estimation"
    authors:
      - name: "Microsoft Research"
    version: "0.x"
