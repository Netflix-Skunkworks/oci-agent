date-released: "2026-05-28"
keywords:
  - causal-inference
  - observational-data
  - doubly-robust
  - DRLearner
  - actor-critic
  - LLM-agents

references:
  - type: article
    title: "Automated versus do-it-yourself methods for causal inference: Lessons learned from a data challenge"
    authors:
      - family-names: Dorie
        given-names: Vincent
      - family-names: Hill
        given-names: "Jennifer L."
      - family-names: Shalit
        given-names: Uri
